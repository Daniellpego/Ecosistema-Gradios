# ══════════════════════════════════════════════════════════════
# apps/site — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ══════════════════════════════════════════════════════════════

# ── Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# ── Anthropic (LLM — used only in /api/diagnostico) ───────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Upstash Redis (global rate limiting via middleware.ts) ─────
# Create a free Redis database at https://console.upstash.com
# Dashboard → Database → REST API → copy Endpoint + Token
UPSTASH_REDIS_REST_URL=https://<db>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>

# ── Email template webhook (n8n → /api/email-template) ────────
# Generate with: openssl rand -hex 32
EMAIL_TEMPLATE_SECRET=<32-byte-hex-secret>

# ── Meta Conversions API (/api/meta-conversion) ───────────────
META_PIXEL_ID=<pixel-id>
META_ACCESS_TOKEN=<system-user-access-token>
