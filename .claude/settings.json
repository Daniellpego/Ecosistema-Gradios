{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_comment": "Settings do Claude Code para o monorepo Gradios. Versionado no git. Hooks 'exit 2' garantem proteção determinística contra: edição de .env, alteração de migrations aplicadas, comandos destrutivos. Ver .claude/hooks/README.md.",

  "permissions": {
    "deny": [
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Bash(rm -rf .git*)",
      "Bash(rm -rf node_modules/.git*)",
      "Bash(npm publish*)"
    ],
    "ask": [
      "Bash(supabase db push*)",
      "Bash(supabase secrets *)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(vercel*)"
    ]
  },

  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/protect_env.sh" },
          { "type": "command", "command": "bash .claude/hooks/protect_migrations.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash .claude/hooks/protect_migrations.sh" },
          { "type": "command", "command": "bash .claude/hooks/protect_dangerous_bash.sh" }
        ]
      }
    ]
  }
}
