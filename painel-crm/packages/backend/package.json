    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@prisma/client": "^5.20.0",
    "@supabase/supabase-js": "^2.98.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.0",
