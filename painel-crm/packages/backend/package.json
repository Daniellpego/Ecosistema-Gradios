{
  "name": "@crm-bgtech/backend",
  "version": "0.1.0",
  "private": true,
  "description": "CRM BG Tech — NestJS Backend",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "start:worker": "ts-node src/agents/agent-worker-runner.ts",
