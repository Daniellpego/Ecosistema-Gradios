datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ────────────────────────────── MULTI-TENANCY ──────────────────────────────

model Tenant {
  id        String   @id @default(uuid())
  name      String
  domain    String?  @unique
  plan      String   @default("starter") // starter, professional, enterprise
  settings  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  users         User[]
  accounts      Account[]
  contacts      Contact[]
  opportunities Opportunity[]
  resources     Resource[]
  projects      Project[]
  slas          SLA[]
  proposals     Proposal[]
  contracts     Contract[]
  agentLogs     AgentLog[]
  leads         Lead[]

  @@map("tenants")
}

// ────────────────────────────── USERS / AUTH ──────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String?  @map("password_hash")
  tenantId     String   @map("tenant_id")
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  role         String   @default("sales") // admin, manager, engineer, sales, finance
  avatarUrl    String?  @map("avatar_url")
  lastLoginAt  DateTime? @map("last_login_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("users")
}

// ────────────────────────────── ACCOUNTS ──────────────────────────────

model Account {
  id         String   @id @default(uuid())
  tenantId   String   @map("tenant_id")
  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  name       String
  industry   String?
  website    String?
  size       String?  // SMB, Mid-Market, Enterprise
  annualRevenue Float? @map("annual_revenue")
  meta       Json?    @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  contacts      Contact[]
  opportunities Opportunity[]
  projects      Project[]
  slas          SLA[]
  proposals     Proposal[]
  contracts     Contract[]

  @@index([tenantId])
  @@map("accounts")
}

// ────────────────────────────── CONTACTS ──────────────────────────────

model Contact {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  accountId   String?  @map("account_id")
  account     Account? @relation(fields: [accountId], references: [id])
  name        String
  email       String?
  phone       String?
  role        String?  // CTO, CEO, Tech Lead, etc.
  department  String?
  linkedinUrl String?  @map("linkedin_url")
  meta        Json?    @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([accountId])
  @@map("contacts")
}

// ────────────────────────────── OPPORTUNITIES ──────────────────────────────

model Opportunity {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  accountId         String   @map("account_id")
  account           Account  @relation(fields: [accountId], references: [id])
  title             String
  description       String?
  value             Float    @default(0)
  stage             String   @default("lead") // lead, qualified, proposal, negotiation, closed_won, closed_lost
  probability       Int      @default(0)
  expectedCloseDate DateTime? @map("expected_close_date")
  technicalEstimate Json?    @map("technical_estimate")
  qualificationData Json?    @map("qualification_data")
  source            String?  // inbound, outbound, referral, partner
  lostReason        String?  @map("lost_reason")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  proposals  Proposal[]
  agentLogs  AgentLog[]

  @@index([tenantId])
  @@index([accountId])
  @@index([stage])
  @@map("opportunities")
}

// ────────────────────────────── RESOURCES ──────────────────────────────

model Resource {
  id           String @id @default(uuid())
  tenantId     String @map("tenant_id")
  tenant       Tenant @relation(fields: [tenantId], references: [id])
  name         String
  title        String
  email        String?
  costPerHour  Float  @map("cost_per_hour")
  billableRate Float? @map("billable_rate")
  skills       Json?  @default("[]")
  availability Json?  @default("{}")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@map("resources")
}

// ────────────────────────────── PROJECTS ──────────────────────────────

model Project {
  id            String   @id @default(uuid())
  tenantId      String   @map("tenant_id")
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  accountId     String   @map("account_id")
  account       Account  @relation(fields: [accountId], references: [id])
  name          String
  status        String   @default("planning") // planning, active, on_hold, completed, cancelled
  startDate     DateTime? @map("start_date")
  endDate       DateTime? @map("end_date")
  milestones    Json?    @default("[]")
  marginEst     Float?   @map("margin_est")
  marginReal    Float?   @map("margin_real")
  budgetHours   Float?   @map("budget_hours")
  actualHours   Float?   @map("actual_hours")
  meta          Json?    @default("{}")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([accountId])
  @@map("projects")
}

// ────────────────────────────── SLAs ──────────────────────────────

model SLA {
  id          String   @id @default(uuid())
  tenantId    String   @map("tenant_id")
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  accountId   String   @map("account_id")
  account     Account  @relation(fields: [accountId], references: [id])
  description String
  tier        Int      @default(1) // 1=Gold, 2=Silver, 3=Bronze
  metrics     Json?    @default("{}")
  startDate   DateTime? @map("start_date")
  renewAt     DateTime @map("renew_at")
  status      String   @default("active") // active, expiring, expired, renewed
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([accountId])
  @@map("slas")
}

// ────────────────────────────── PROPOSALS ──────────────────────────────

model Proposal {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  accountId       String   @map("account_id")
  account         Account  @relation(fields: [accountId], references: [id])
  opportunityId   String   @map("opportunity_id")
  opportunity     Opportunity @relation(fields: [opportunityId], references: [id])
  title           String
  version         Int      @default(1)
  status          String   @default("draft") // draft, review, approved, sent, accepted, rejected
  contentMarkdown String?  @map("content_markdown") @db.Text
  contentHtml     String?  @map("content_html") @db.Text
  estimatedValue  Float?   @map("estimated_value")
  effortBreakdown Json?    @map("effort_breakdown")
  riskAssessment  Json?    @map("risk_assessment")
  validUntil      DateTime? @map("valid_until")
  verificationLog Json?    @map("verification_log")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  contracts Contract[]

  @@index([tenantId])
  @@index([opportunityId])
  @@map("proposals")
}

// ────────────────────────────── CONTRACTS (CLM) ──────────────────────────────

model Contract {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  accountId       String   @map("account_id")
  account         Account  @relation(fields: [accountId], references: [id])
  proposalId      String?  @map("proposal_id")
  proposal        Proposal? @relation(fields: [proposalId], references: [id])
  title           String
  status          String   @default("draft") // draft, legal_review, approved, signed, active, expired
  contentMarkdown String?  @map("content_markdown") @db.Text
  clauses         Json?    @default("[]")
  signedAt        DateTime? @map("signed_at")
  expiresAt       DateTime? @map("expires_at")
  signatureData   Json?    @map("signature_data") // placeholder for e-sign
  meta            Json?    @default("{}")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([tenantId])
  @@index([proposalId])
  @@map("contracts")
}

// ────────────────────────────── AGENT LOGS ──────────────────────────────

model AgentLog {
  id              String   @id @default(uuid())
  tenantId        String   @map("tenant_id")
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  opportunityId   String?  @map("opportunity_id")
  opportunity     Opportunity? @relation(fields: [opportunityId], references: [id])
  leadId          String?  @map("lead_id")
  lead            Lead?    @relation(fields: [leadId], references: [id])
  agentName       String   @map("agent_name")
  action          String
  input           Json?
  output          Json?
  tokensUsed      Int?     @map("tokens_used")
  latencyMs       Int?     @map("latency_ms")
  status          String   @default("success") // success, error, timeout
  errorMessage    String?  @map("error_message")
  model           String?
  createdAt       DateTime @default(now()) @map("created_at")

  @@index([tenantId])
  @@index([opportunityId])
  @@index([leadId])
  @@index([agentName])
  @@map("agent_logs")
}

// ────────────────────────────── LEADS (Quiz / Facebook) ──────────────────────────────

model Lead {
  id                String   @id @default(uuid())
  tenantId          String   @map("tenant_id")
  tenant            Tenant   @relation(fields: [tenantId], references: [id])
  nome              String?
  empresa           String?
  email             String?
  whatsapp          String?
  segmento          String?
  horasPerdidas     String?  @map("horas_perdidas")
  dorPrincipal      String?  @map("dor_principal")
  faturamento       String?
  maturidade        String?
  janelaDecisao     String?  @map("janela_decisao")
  leadTemperature   String?  @map("lead_temperature")
  score             Int?
  custoMensal       String?  @map("custo_mensal")
  diagnosticoId     String?  @map("diagnostico_id")
  rawQuizResponse   Json?    @map("raw_quiz_response")
  leadStatus        String   @default("new") @map("lead_status") // new, qualified, nurture, disqualified, converted
  leadTags          String[] @default([]) @map("lead_tags")
  consent           Boolean  @default(true)
  opportunityId     String?  @map("opportunity_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  agentLogs         AgentLog[]

  @@index([tenantId])
  @@index([whatsapp])
  @@index([email])
  @@index([leadStatus])
  @@map("leads")
}
