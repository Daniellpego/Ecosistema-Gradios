{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ChurnAgentOutput",
  "description": "Structured output expected from the Churn Prevention Agent",
  "type": "object",
  "required": [
    "churn_probability",
    "risk_signals",
    "health_score",
    "recommended_actions",
    "urgency",
    "retention_strategy"
  ],
  "additionalProperties": false,
  "properties": {
    "churn_probability": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Probability of churn (0-1)"
    },
    "risk_signals": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Identified churn risk signals"
    },
    "health_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100,
      "description": "Account health score (0-100)"
    },
    "recommended_actions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Recommended preventive actions"
    },
    "urgency": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "retention_strategy": {
      "type": "string",
      "description": "Overall retention strategy recommendation"
    }
  }
}
