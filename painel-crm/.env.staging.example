# ──────────────────────────────────────────────────
# CRM BG Tech — Staging Environment Variables
# Copy to .env.staging and fill in real values
# ──────────────────────────────────────────────────

# ─── Database ────────────────────────────────────
DATABASE_URL=postgresql://crm:crm_secret_2026@postgres:5432/crm_bgtech

# ─── Redis (BullMQ + Budget Tracking) ───────────
REDIS_URL=redis://redis:6379

# ─── Auth ────────────────────────────────────────
# MUST be a strong random secret (≥32 chars). No fallback in production.
JWT_SECRET=CHANGE_ME_TO_RANDOM_SECRET_32_CHARS_MIN

# ─── LLM Configuration ──────────────────────────
# Provider: 'mock' | 'openai' | 'anthropic'
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=sk-PASTE_YOUR_KEY_HERE
OPENAI_MODEL=gpt-4o-mini

# Budget guard (per-tenant monthly limit in USD)
# Redis-backed, atomic INCRBY, auto-resets monthly
LLM_MONTHLY_BUDGET_USD=10

# ─── Worker ──────────────────────────────────────
WORKER_CONCURRENCY=2

# ─── Backend ─────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Frontend (build-time) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001/api
